   DEBUG: 2026-02-20 18:00:09,094:      pdf_renderer.py:  470: printSegment:             if idx < 0:
   DEBUG: 2026-02-20 18:00:09,094:      pdf_renderer.py:  470: printSegment:                 continue
   DEBUG: 2026-02-20 18:00:09,095:      pdf_renderer.py:  470: printSegment:             row = self.metadata.filter(pl.col("faiss_idx") == idx)
   DEBUG: 2026-02-20 18:00:09,095:      pdf_renderer.py:  470: printSegment:             if row.is_empty():
   DEBUG: 2026-02-20 18:00:09,096:      pdf_renderer.py:  470: printSegment:                 continue
   DEBUG: 2026-02-20 18:00:09,096:      pdf_renderer.py:  470: printSegment:             entry = row.to_dicts()[0]
   DEBUG: 2026-02-20 18:00:09,097:      pdf_renderer.py:  470: printSegment:             entry["score"] = float(scores[0, i])
   DEBUG: 2026-02-20 18:00:09,097:      pdf_renderer.py:  470: printSegment:             results.append(entry)
   DEBUG: 2026-02-20 18:00:09,097:      pdf_renderer.py:  470: printSegment:         return results
   DEBUG: 2026-02-20 18:00:09,098:      pdf_renderer.py:  470: printSegment:     def get_embedding(self, faiss_idx: int) -> np.ndarray:
   DEBUG: 2026-02-20 18:00:09,098:      pdf_renderer.py:  470: printSegment:         """Retrieve the stored embedding for a given FAISS index
   DEBUG: 2026-02-20 18:00:09,099:      pdf_renderer.py:  470: printSegment: position."""
