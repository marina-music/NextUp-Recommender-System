   DEBUG: 2026-02-20 18:00:09,607:      pdf_renderer.py:  470: printSegment: content_scores.items() if k not in history_set}
   DEBUG: 2026-02-20 18:00:09,608:      pdf_renderer.py:  470: printSegment:             mamba_scores = {k: v for k, v in mamba_scores.items()
   DEBUG: 2026-02-20 18:00:09,608:      pdf_renderer.py:  470: printSegment: if k not in history_set}
   DEBUG: 2026-02-20 18:00:09,609:      pdf_renderer.py:  470: printSegment:         # Determine mode
