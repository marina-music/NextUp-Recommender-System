   DEBUG: 2026-02-20 18:00:08,961:      pdf_renderer.py:  470: printSegment:     metadata_path: Path = DATA_DIR / "plots_metadata.parquet",
   DEBUG: 2026-02-20 18:00:08,961:      pdf_renderer.py:  470: printSegment: ):
   DEBUG: 2026-02-20 18:00:08,962:      pdf_renderer.py:  470: printSegment:     """Encode all plots and build FAISS index.
   DEBUG: 2026-02-20 18:00:08,962:      pdf_renderer.py:  470: printSegment:     Args:
   DEBUG: 2026-02-20 18:00:08,963:      pdf_renderer.py:  470: printSegment:         plots_df: DataFrame with columns: wiki_title or title,
   DEBUG: 2026-02-20 18:00:08,963:      pdf_renderer.py:  470: printSegment: plot_text,
   DEBUG: 2026-02-20 18:00:08,964:      pdf_renderer.py:  470: printSegment:                   and optionally genres, year, plot_source.
   DEBUG: 2026-02-20 18:00:08,964:      pdf_renderer.py:  470: printSegment:         model_name: Sentence transformer model name.
   DEBUG: 2026-02-20 18:00:08,965:      pdf_renderer.py:  470: printSegment:         batch_size: Encoding batch size.
   DEBUG: 2026-02-20 18:00:08,965:      pdf_renderer.py:  470: printSegment:         index_path: Where to save the FAISS index.
   DEBUG: 2026-02-20 18:00:08,966:      pdf_renderer.py:  470: printSegment:         metadata_path: Where to save the metadata mapping.
   DEBUG: 2026-02-20 18:00:08,966:      pdf_renderer.py:  470: printSegment:     """
   DEBUG: 2026-02-20 18:00:08,967:      pdf_renderer.py:  470: printSegment:     from sentence_transformers import SentenceTransformer
   DEBUG: 2026-02-20 18:00:08,967:      pdf_renderer.py:  470: printSegment:     model = SentenceTransformer(model_name)
   DEBUG: 2026-02-20 18:00:08,967:      pdf_renderer.py:  470: printSegment:     # Determine title column
   DEBUG: 2026-02-20 18:00:08,968:      pdf_renderer.py:  470: printSegment:     title_col = "title" if "title" in plots_df.columns else
   DEBUG: 2026-02-20 18:00:08,969:      pdf_renderer.py:  470: printSegment: "wiki_title"
   DEBUG: 2026-02-20 18:00:08,969:      pdf_renderer.py:  470: printSegment:     # Prepare texts with metadata
   DEBUG: 2026-02-20 18:00:08,969:      pdf_renderer.py:  470: printSegment:     texts = []
   DEBUG: 2026-02-20 18:00:08,970:      pdf_renderer.py:  470: printSegment:     for row in tqdm(plots_df.iter_rows(named=True),
   DEBUG: 2026-02-20 18:00:08,971:      pdf_renderer.py:  470: printSegment: total=len(plots_df), desc="Preparing texts"):
   DEBUG: 2026-02-20 18:00:08,972:      pdf_renderer.py:  470: printSegment:         title = row.get(title_col, "")
   DEBUG: 2026-02-20 18:00:08,972:      pdf_renderer.py:  470: printSegment:         genres = row.get("genres", None)
   DEBUG: 2026-02-20 18:00:08,973:      pdf_renderer.py:  470: printSegment:         year = row.get("year", None)
   DEBUG: 2026-02-20 18:00:08,973:      pdf_renderer.py:  470: printSegment:         plot_source = row.get("plot_source", "")
   DEBUG: 2026-02-20 18:00:08,974:      pdf_renderer.py:  470: printSegment:         media_type = "Film"  # Default; could detect from genres
   DEBUG: 2026-02-20 18:00:08,974:      pdf_renderer.py:  470: printSegment:         if genres and "Animation" in str(genres):
   DEBUG: 2026-02-20 18:00:08,975:      pdf_renderer.py:  470: printSegment:             media_type = "Animated Film"
   DEBUG: 2026-02-20 18:00:08,976:      pdf_renderer.py:  470: printSegment:         text = prepend_metadata(row["plot_text"], media_type,
   DEBUG: 2026-02-20 18:00:08,976:      pdf_renderer.py:  470: printSegment: genres, year, title)
   DEBUG: 2026-02-20 18:00:08,977:      pdf_renderer.py:  470: printSegment:         texts.append(text)
   DEBUG: 2026-02-20 18:00:08,977:      pdf_renderer.py:  470: printSegment:     # Encode in batches
   DEBUG: 2026-02-20 18:00:08,978:      pdf_renderer.py:  470: printSegment:     print(f"Encoding {len(texts)} plots with {model_name}...")
   DEBUG: 2026-02-20 18:00:08,978:      pdf_renderer.py:  470: printSegment:     all_embeddings = model.encode(
   DEBUG: 2026-02-20 18:00:08,979:      pdf_renderer.py:  470: printSegment:         texts,
   DEBUG: 2026-02-20 18:00:08,979:      pdf_renderer.py:  470: printSegment:         batch_size=batch_size,
   DEBUG: 2026-02-20 18:00:08,980:      pdf_renderer.py:  470: printSegment:         show_progress_bar=True,
   DEBUG: 2026-02-20 18:00:08,980:      pdf_renderer.py:  470: printSegment:         normalize_embeddings=True,
   DEBUG: 2026-02-20 18:00:08,981:      pdf_renderer.py:  470: printSegment:         convert_to_numpy=True,
   DEBUG: 2026-02-20 18:00:08,981:      pdf_renderer.py:  470: printSegment:     )
   DEBUG: 2026-02-20 18:00:08,981:      pdf_renderer.py:  470: printSegment:     all_embeddings = all_embeddings.astype(np.float32)
   DEBUG: 2026-02-20 18:00:08,982:      pdf_renderer.py:  470: printSegment:     print(f"Embeddings shape: {all_embeddings.shape}")
   DEBUG: 2026-02-20 18:00:08,982:      pdf_renderer.py:  470: printSegment:     # Build FAISS index
   DEBUG: 2026-02-20 18:00:08,983:      pdf_renderer.py:  470: printSegment:     index = faiss.IndexFlatIP(all_embeddings.shape[1])
   DEBUG: 2026-02-20 18:00:08,983:      pdf_renderer.py:  470: printSegment:     index.add(all_embeddings)
   DEBUG: 2026-02-20 18:00:08,984:      pdf_renderer.py:  470: printSegment:     print(f"FAISS index: {index.ntotal} vectors, {index.d}
   DEBUG: 2026-02-20 18:00:08,984:      pdf_renderer.py:  470: printSegment: dimensions")
   DEBUG: 2026-02-20 18:00:08,984:      pdf_renderer.py:  470: printSegment:     # Save index
   DEBUG: 2026-02-20 18:00:08,985:      pdf_renderer.py:  470: printSegment:     index_path.parent.mkdir(parents=True, exist_ok=True)
   DEBUG: 2026-02-20 18:00:08,985:      pdf_renderer.py:  470: printSegment:     faiss.write_index(index, str(index_path))
   DEBUG: 2026-02-20 18:00:08,986:      pdf_renderer.py:  470: printSegment:     print(f"Saved FAISS index to {index_path}")
   DEBUG: 2026-02-20 18:00:08,986:      pdf_renderer.py:  470: printSegment:     # Save metadata (position → movie info mapping)
   DEBUG: 2026-02-20 18:00:08,993:      pdf_renderer.py:  470: printSegment:     metadata_cols = [c for c in plots_df.columns if c !=
   DEBUG: 2026-02-20 18:00:08,993:      pdf_renderer.py:  470: printSegment: "plot_text"]
