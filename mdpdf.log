   DEBUG: 2026-02-20 18:00:08,574:      pdf_renderer.py:  470: printSegment: """Single-phase Mamba4Rec training with retraining support."""
   DEBUG: 2026-02-20 18:00:08,574:      pdf_renderer.py:  470: printSegment: import sys
   DEBUG: 2026-02-20 18:00:08,574:      pdf_renderer.py:  470: printSegment: import os
