   DEBUG: 2026-02-20 18:00:08,840:      pdf_renderer.py:  470: printSegment: """Filter wiki_plots_raw.parquet to movies/TV only via Wikidata
   DEBUG: 2026-02-20 18:00:08,840:      pdf_renderer.py:  470: printSegment: SPARQL."""
   DEBUG: 2026-02-20 18:00:08,841:      pdf_renderer.py:  470: printSegment: import json
   DEBUG: 2026-02-20 18:00:08,841:      pdf_renderer.py:  470: printSegment: import time
   DEBUG: 2026-02-20 18:00:08,841:      pdf_renderer.py:  470: printSegment: from pathlib import Path
