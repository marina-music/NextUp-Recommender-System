   DEBUG: 2026-02-20 18:00:08,575:      pdf_renderer.py:  470: printSegment: import logging
   DEBUG: 2026-02-20 18:00:08,576:      pdf_renderer.py:  470: printSegment: from pathlib import Path
   DEBUG: 2026-02-20 18:00:08,576:      pdf_renderer.py:  470: printSegment: import torch
   DEBUG: 2026-02-20 18:00:08,577:      pdf_renderer.py:  470: printSegment: from torch.optim import Adam
   DEBUG: 2026-02-20 18:00:08,577:      pdf_renderer.py:  470: printSegment: from torch.optim.lr_scheduler import CosineAnnealingLR
   DEBUG: 2026-02-20 18:00:08,578:      pdf_renderer.py:  470: printSegment: from recbole.config import Config
   DEBUG: 2026-02-20 18:00:08,579:      pdf_renderer.py:  470: printSegment: from recbole.data import create_dataset, data_preparation
   DEBUG: 2026-02-20 18:00:08,579:      pdf_renderer.py:  470: printSegment: from recbole.trainer import Trainer
   DEBUG: 2026-02-20 18:00:08,580:      pdf_renderer.py:  470: printSegment: from recbole.utils import init_seed, init_logger
   DEBUG: 2026-02-20 18:00:08,580:      pdf_renderer.py:  470: printSegment: from mamba4rec import Mamba4Rec
   DEBUG: 2026-02-20 18:00:08,581:      pdf_renderer.py:  470: printSegment: # PyTorch 2.6+ compat
   DEBUG: 2026-02-20 18:00:08,581:      pdf_renderer.py:  470: printSegment: _original_torch_load = torch.load
   DEBUG: 2026-02-20 18:00:08,582:      pdf_renderer.py:  470: printSegment: def _patched_torch_load(*args, **kwargs):
   DEBUG: 2026-02-20 18:00:08,582:      pdf_renderer.py:  470: printSegment:     kwargs.setdefault("weights_only", False)
   DEBUG: 2026-02-20 18:00:08,583:      pdf_renderer.py:  470: printSegment:     return _original_torch_load(*args, **kwargs)
   DEBUG: 2026-02-20 18:00:08,583:      pdf_renderer.py:  470: printSegment: torch.load = _patched_torch_load
   DEBUG: 2026-02-20 18:00:08,583:      pdf_renderer.py:  470: printSegment: logger = logging.getLogger(__name__)
   DEBUG: 2026-02-20 18:00:08,584:      pdf_renderer.py:  470: printSegment: def expand_item_embeddings(model, new_num_items):
   DEBUG: 2026-02-20 18:00:08,585:      pdf_renderer.py:  470: printSegment:     """Expand the item embedding table for retraining with
   DEBUG: 2026-02-20 18:00:08,585:      pdf_renderer.py:  470: printSegment: graduated movies.
   DEBUG: 2026-02-20 18:00:08,585:      pdf_renderer.py:  470: printSegment:     Args:
   DEBUG: 2026-02-20 18:00:08,586:      pdf_renderer.py:  470: printSegment:         model: Mamba4Rec model with existing embeddings.
   DEBUG: 2026-02-20 18:00:08,586:      pdf_renderer.py:  470: printSegment:         new_num_items: New total number of items (must be >=
   DEBUG: 2026-02-20 18:00:08,587:      pdf_renderer.py:  470: printSegment: current).
   DEBUG: 2026-02-20 18:00:08,587:      pdf_renderer.py:  470: printSegment:     Returns:
   DEBUG: 2026-02-20 18:00:08,588:      pdf_renderer.py:  470: printSegment:         Model with expanded embedding table (new rows randomly
   DEBUG: 2026-02-20 18:00:08,588:      pdf_renderer.py:  470: printSegment: initialized).
   DEBUG: 2026-02-20 18:00:08,588:      pdf_renderer.py:  470: printSegment:     """
   DEBUG: 2026-02-20 18:00:08,589:      pdf_renderer.py:  470: printSegment:     old_emb = model.item_embedding
   DEBUG: 2026-02-20 18:00:08,589:      pdf_renderer.py:  470: printSegment:     old_num, emb_dim = old_emb.weight.shape
   DEBUG: 2026-02-20 18:00:08,590:      pdf_renderer.py:  470: printSegment:     if new_num_items <= old_num:
   DEBUG: 2026-02-20 18:00:08,590:      pdf_renderer.py:  470: printSegment:         return model
   DEBUG: 2026-02-20 18:00:08,591:      pdf_renderer.py:  470: printSegment:     new_emb = torch.nn.Embedding(new_num_items, emb_dim,
   DEBUG: 2026-02-20 18:00:08,591:      pdf_renderer.py:  470: printSegment: padding_idx=0)
   DEBUG: 2026-02-20 18:00:08,591:      pdf_renderer.py:  470: printSegment:     with torch.no_grad():
   DEBUG: 2026-02-20 18:00:08,592:      pdf_renderer.py:  470: printSegment:         new_emb.weight[:old_num] = old_emb.weight
   DEBUG: 2026-02-20 18:00:08,593:      pdf_renderer.py:  470: printSegment:         torch.nn.init.normal_(new_emb.weight[old_num:], mean=0.0,
   DEBUG: 2026-02-20 18:00:08,593:      pdf_renderer.py:  470: printSegment: std=0.02)
   DEBUG: 2026-02-20 18:00:08,593:      pdf_renderer.py:  470: printSegment:     model.item_embedding = new_emb
   DEBUG: 2026-02-20 18:00:08,594:      pdf_renderer.py:  470: printSegment:     logger.info(f"Expanded embeddings: {old_num} -> {new_num_items}
   DEBUG: 2026-02-20 18:00:08,594:      pdf_renderer.py:  470: printSegment: items")
   DEBUG: 2026-02-20 18:00:08,595:      pdf_renderer.py:  470: printSegment:     return model
   DEBUG: 2026-02-20 18:00:08,595:      pdf_renderer.py:  470: printSegment: def train_mamba(config_path, save_dir="checkpoints",
   DEBUG: 2026-02-20 18:00:08,596:      pdf_renderer.py:  470: printSegment: checkpoint=None):
   DEBUG: 2026-02-20 18:00:08,596:      pdf_renderer.py:  470: printSegment:     """Train Mamba4Rec from scratch or continue from checkpoint.
   DEBUG: 2026-02-20 18:00:08,597:      pdf_renderer.py:  470: printSegment:     Args:
   DEBUG: 2026-02-20 18:00:08,597:      pdf_renderer.py:  470: printSegment:         config_path: Path to YAML config file.
   DEBUG: 2026-02-20 18:00:08,598:      pdf_renderer.py:  470: printSegment:         save_dir: Directory to save the trained model.
   DEBUG: 2026-02-20 18:00:08,598:      pdf_renderer.py:  470: printSegment:         checkpoint: Optional path to existing checkpoint for
   DEBUG: 2026-02-20 18:00:08,599:      pdf_renderer.py:  470: printSegment: retraining.
   DEBUG: 2026-02-20 18:00:08,599:      pdf_renderer.py:  470: printSegment:     Returns:
   DEBUG: 2026-02-20 18:00:08,600:      pdf_renderer.py:  470: printSegment:         Tuple of (model, test_result).
   DEBUG: 2026-02-20 18:00:08,600:      pdf_renderer.py:  470: printSegment:     """
   DEBUG: 2026-02-20 18:00:08,600:      pdf_renderer.py:  470: printSegment:     save_dir = Path(save_dir)
   DEBUG: 2026-02-20 18:00:08,601:      pdf_renderer.py:  470: printSegment:     save_dir.mkdir(parents=True, exist_ok=True)
   DEBUG: 2026-02-20 18:00:08,602:      pdf_renderer.py:  470: printSegment:     config = Config(model=Mamba4Rec,
   DEBUG: 2026-02-20 18:00:08,602:      pdf_renderer.py:  470: printSegment: config_file_list=[config_path])
   DEBUG: 2026-02-20 18:00:08,603:      pdf_renderer.py:  470: printSegment:     init_seed(config["seed"], config["reproducibility"])
   DEBUG: 2026-02-20 18:00:08,603:      pdf_renderer.py:  470: printSegment:     init_logger(config)
   DEBUG: 2026-02-20 18:00:08,604:      pdf_renderer.py:  470: printSegment:     dataset = create_dataset(config)
   DEBUG: 2026-02-20 18:00:08,604:      pdf_renderer.py:  470: printSegment:     train_data, valid_data, test_data = data_preparation(config,
   DEBUG: 2026-02-20 18:00:08,605:      pdf_renderer.py:  470: printSegment: dataset)
   DEBUG: 2026-02-20 18:00:08,605:      pdf_renderer.py:  470: printSegment:     model = Mamba4Rec(config, dataset).to(config["device"])
   DEBUG: 2026-02-20 18:00:08,606:      pdf_renderer.py:  470: printSegment:     if checkpoint:
   DEBUG: 2026-02-20 18:00:08,607:      pdf_renderer.py:  470: printSegment:         state = torch.load(checkpoint,
   DEBUG: 2026-02-20 18:00:08,607:      pdf_renderer.py:  470: printSegment: map_location=config["device"])
   DEBUG: 2026-02-20 18:00:08,608:      pdf_renderer.py:  470: printSegment:         model_state = state.get("state_dict", state)
   DEBUG: 2026-02-20 18:00:08,608:      pdf_renderer.py:  470: printSegment:         # Handle embedding size mismatch for retraining
   DEBUG: 2026-02-20 18:00:08,609:      pdf_renderer.py:  470: printSegment:         old_num = model_state["item_embedding.weight"].shape[0]
   DEBUG: 2026-02-20 18:00:08,609:      pdf_renderer.py:  470: printSegment:         new_num = model.item_embedding.weight.shape[0]
   DEBUG: 2026-02-20 18:00:08,610:      pdf_renderer.py:  470: printSegment:         if new_num > old_num:
   DEBUG: 2026-02-20 18:00:08,610:      pdf_renderer.py:  470: printSegment:             model = expand_item_embeddings(model, new_num)
   DEBUG: 2026-02-20 18:00:08,611:      pdf_renderer.py:  470: printSegment:             model.load_state_dict(model_state, strict=False)
   DEBUG: 2026-02-20 18:00:08,611:      pdf_renderer.py:  470: printSegment:         else:
   DEBUG: 2026-02-20 18:00:08,612:      pdf_renderer.py:  470: printSegment:             model.load_state_dict(model_state)
   DEBUG: 2026-02-20 18:00:08,612:      pdf_renderer.py:  470: printSegment:         logger.info(f"Loaded checkpoint from {checkpoint}")
   DEBUG: 2026-02-20 18:00:08,613:      pdf_renderer.py:  470: printSegment:     total = sum(p.numel() for p in model.parameters())
   DEBUG: 2026-02-20 18:00:08,613:      pdf_renderer.py:  470: printSegment:     trainable = sum(p.numel() for p in model.parameters() if
   DEBUG: 2026-02-20 18:00:08,614:      pdf_renderer.py:  470: printSegment: p.requires_grad)
   DEBUG: 2026-02-20 18:00:08,614:      pdf_renderer.py:  470: printSegment:     logger.info(f"Parameters: {total:,} total, {trainable:,}
   DEBUG: 2026-02-20 18:00:08,615:      pdf_renderer.py:  470: printSegment: trainable")
   DEBUG: 2026-02-20 18:00:08,615:      pdf_renderer.py:  470: printSegment:     trainer = Trainer(config, model)
   DEBUG: 2026-02-20 18:00:08,616:      pdf_renderer.py:  470: printSegment:     best_valid_score, best_valid_result = trainer.fit(
   DEBUG: 2026-02-20 18:00:08,616:      pdf_renderer.py:  470: printSegment:         train_data, valid_data, show_progress=True
   DEBUG: 2026-02-20 18:00:08,616:      pdf_renderer.py:  470: printSegment:     )
   DEBUG: 2026-02-20 18:00:08,617:      pdf_renderer.py:  470: printSegment:     test_result = trainer.evaluate(test_data)
   DEBUG: 2026-02-20 18:00:08,617:      pdf_renderer.py:  470: printSegment:     logger.info(f"Best valid: {best_valid_result}")
