   DEBUG: 2026-02-20 18:00:09,625:      pdf_renderer.py:  470: printSegment: self.encoder.encode_query(query_text).cpu().numpy()
   DEBUG: 2026-02-20 18:00:09,625:      pdf_renderer.py:  470: printSegment:         # Gather candidates from all users
   DEBUG: 2026-02-20 18:00:09,626:      pdf_renderer.py:  470: printSegment:         all_candidates = set()
   DEBUG: 2026-02-20 18:00:09,626:      pdf_renderer.py:  470: printSegment:         for user in users:
   DEBUG: 2026-02-20 18:00:09,627:      pdf_renderer.py:  470: printSegment:             user_id = user.get("user_id")
   DEBUG: 2026-02-20 18:00:09,627:      pdf_renderer.py:  470: printSegment:             history = user.get("item_history", [])
   DEBUG: 2026-02-20 18:00:09,627:      pdf_renderer.py:  470: printSegment:             profile = user.get("profile_embedding")
   DEBUG: 2026-02-20 18:00:09,628:      pdf_renderer.py:  470: printSegment:             if self.mamba_model and history:
   DEBUG: 2026-02-20 18:00:09,628:      pdf_renderer.py:  470: printSegment:                 mamba_top = self._get_mamba_scores(history,
   DEBUG: 2026-02-20 18:00:09,629:      pdf_renderer.py:  470: printSegment: top_k=50)
   DEBUG: 2026-02-20 18:00:09,629:      pdf_renderer.py:  470: printSegment:                 all_candidates |= set(mamba_top.keys())
   DEBUG: 2026-02-20 18:00:09,630:      pdf_renderer.py:  470: printSegment:             if self.content_tower and profile is not None:
   DEBUG: 2026-02-20 18:00:09,630:      pdf_renderer.py:  470: printSegment:                 profile_results = self.content_tower.search(
   DEBUG: 2026-02-20 18:00:09,631:      pdf_renderer.py:  470: printSegment:                     profile_embedding=profile, top_k=30
   DEBUG: 2026-02-20 18:00:09,631:      pdf_renderer.py:  470: printSegment:                 )
   DEBUG: 2026-02-20 18:00:09,632:      pdf_renderer.py:  470: printSegment:                 all_candidates |= {r["movieId"] for r in
   DEBUG: 2026-02-20 18:00:09,632:      pdf_renderer.py:  470: printSegment: profile_results}
   DEBUG: 2026-02-20 18:00:09,633:      pdf_renderer.py:  470: printSegment:         if self.content_tower and query_embedding is not None:
   DEBUG: 2026-02-20 18:00:09,633:      pdf_renderer.py:  470: printSegment:             query_results = self.content_tower.search(
   DEBUG: 2026-02-20 18:00:09,634:      pdf_renderer.py:  470: printSegment:                 query_embedding=query_embedding, top_k=50
   DEBUG: 2026-02-20 18:00:09,634:      pdf_renderer.py:  470: printSegment:             )
   DEBUG: 2026-02-20 18:00:09,635:      pdf_renderer.py:  470: printSegment:             all_candidates |= {r["movieId"] for r in query_results}
   DEBUG: 2026-02-20 18:00:09,635:      pdf_renderer.py:  470: printSegment:         if not all_candidates:
   DEBUG: 2026-02-20 18:00:09,636:      pdf_renderer.py:  470: printSegment:             return []
   DEBUG: 2026-02-20 18:00:09,636:      pdf_renderer.py:  470: printSegment:         # Score each candidate per user
   DEBUG: 2026-02-20 18:00:09,636:      pdf_renderer.py:  470: printSegment:         per_movie_scores = {}
