   DEBUG: 2026-02-20 18:00:09,616:      pdf_renderer.py:  470: printSegment:         query_text: Optional[str] = None,
   DEBUG: 2026-02-20 18:00:09,617:      pdf_renderer.py:  470: printSegment:         top_k: int = 10,
   DEBUG: 2026-02-20 18:00:09,617:      pdf_renderer.py:  470: printSegment:         fairness_lambda: float = 0.5,
   DEBUG: 2026-02-20 18:00:09,618:      pdf_renderer.py:  470: printSegment:     ) -> List[Dict]:
   DEBUG: 2026-02-20 18:00:09,618:      pdf_renderer.py:  470: printSegment:         """Generate group recommendations.
   DEBUG: 2026-02-20 18:00:09,618:      pdf_renderer.py:  470: printSegment:         Args:
   DEBUG: 2026-02-20 18:00:09,619:      pdf_renderer.py:  470: printSegment:             users: List of user dicts, each with 'user_id' and
   DEBUG: 2026-02-20 18:00:09,620:      pdf_renderer.py:  470: printSegment: optionally
   DEBUG: 2026-02-20 18:00:09,620:      pdf_renderer.py:  470: printSegment:                    'item_history' and 'profile_embedding'.
   DEBUG: 2026-02-20 18:00:09,621:      pdf_renderer.py:  470: printSegment:             query_text: Shared group query text.
   DEBUG: 2026-02-20 18:00:09,621:      pdf_renderer.py:  470: printSegment:             top_k: Number of recommendations.
   DEBUG: 2026-02-20 18:00:09,622:      pdf_renderer.py:  470: printSegment:             fairness_lambda: Penalty for score disagreement.
   DEBUG: 2026-02-20 18:00:09,622:      pdf_renderer.py:  470: printSegment:         Returns:
   DEBUG: 2026-02-20 18:00:09,623:      pdf_renderer.py:  470: printSegment:             List of recommendation dicts.
   DEBUG: 2026-02-20 18:00:09,623:      pdf_renderer.py:  470: printSegment:         """
   DEBUG: 2026-02-20 18:00:09,624:      pdf_renderer.py:  470: printSegment:         query_embedding = None
   DEBUG: 2026-02-20 18:00:09,624:      pdf_renderer.py:  470: printSegment:         if query_text:
