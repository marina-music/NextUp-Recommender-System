   DEBUG: 2026-02-20 18:00:09,602:      pdf_renderer.py:  470: printSegment:         # Mamba arm
   DEBUG: 2026-02-20 18:00:09,602:      pdf_renderer.py:  470: printSegment:         mamba_scores = {}
