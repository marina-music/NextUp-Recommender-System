   DEBUG: 2026-02-20 18:00:09,591:      pdf_renderer.py:  470: printSegment:             alpha = alpha_override
   DEBUG: 2026-02-20 18:00:09,592:      pdf_renderer.py:  470: printSegment:         else:
   DEBUG: 2026-02-20 18:00:09,592:      pdf_renderer.py:  470: printSegment:             alpha = compute_alpha(
   DEBUG: 2026-02-20 18:00:09,593:      pdf_renderer.py:  470: printSegment:                 query_text=query_text,
   DEBUG: 2026-02-20 18:00:09,593:      pdf_renderer.py:  470: printSegment:                 has_profile=has_profile,
