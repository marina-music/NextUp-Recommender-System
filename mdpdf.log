   DEBUG: 2026-02-20 18:00:09,647:      pdf_renderer.py:  470: printSegment:             movie_id: Movie they interacted with.
   DEBUG: 2026-02-20 18:00:09,648:      pdf_renderer.py:  470: printSegment:             rating_weight: Signal strength (+2 for 5-star, -2 for
   DEBUG: 2026-02-20 18:00:09,648:      pdf_renderer.py:  470: printSegment: 1-star,
   DEBUG: 2026-02-20 18:00:09,649:      pdf_renderer.py:  470: printSegment:                           +1 for right swipe, -1 for left swipe).
   DEBUG: 2026-02-20 18:00:09,649:      pdf_renderer.py:  470: printSegment:         """
   DEBUG: 2026-02-20 18:00:09,650:      pdf_renderer.py:  470: printSegment:         if self.content_tower:
   DEBUG: 2026-02-20 18:00:09,650:      pdf_renderer.py:  470: printSegment:             plot_emb =
   DEBUG: 2026-02-20 18:00:09,651:      pdf_renderer.py:  470: printSegment: self.content_tower.get_movie_embedding(movie_id)
   DEBUG: 2026-02-20 18:00:09,651:      pdf_renderer.py:  470: printSegment:             if plot_emb is not None:
   DEBUG: 2026-02-20 18:00:09,652:      pdf_renderer.py:  470: printSegment:                
   DEBUG: 2026-02-20 18:00:09,652:      pdf_renderer.py:  470: printSegment: self.embedding_manager.profile_store.update_with_rating(
   DEBUG: 2026-02-20 18:00:09,653:      pdf_renderer.py:  470: printSegment:                     user_id=user_id,
   DEBUG: 2026-02-20 18:00:09,653:      pdf_renderer.py:  470: printSegment:                     plot_embedding=plot_emb,
   DEBUG: 2026-02-20 18:00:09,653:      pdf_renderer.py:  470: printSegment:                     rating_weight=rating_weight,
   DEBUG: 2026-02-20 18:00:09,654:      pdf_renderer.py:  470: printSegment:                 )
   DEBUG: 2026-02-20 18:00:09,655:      pdf_renderer.py:  470: printSegment:     def _get_mamba_scores(self, item_history: List[int], top_k: int
   DEBUG: 2026-02-20 18:00:09,655:      pdf_renderer.py:  470: printSegment: = 50) -> Dict[int, float]:
   DEBUG: 2026-02-20 18:00:09,656:      pdf_renderer.py:  470: printSegment:         """Get top-K scores from Mamba for a user's history."""
   DEBUG: 2026-02-20 18:00:09,656:      pdf_renderer.py:  470: printSegment:         if self.mamba_model is None:
   DEBUG: 2026-02-20 18:00:09,657:      pdf_renderer.py:  470: printSegment:             return {}
   DEBUG: 2026-02-20 18:00:09,657:      pdf_renderer.py:  470: printSegment:         with torch.no_grad():
   DEBUG: 2026-02-20 18:00:09,658:      pdf_renderer.py:  470: printSegment:             item_seq = torch.tensor([item_history],
   DEBUG: 2026-02-20 18:00:09,658:      pdf_renderer.py:  470: printSegment: dtype=torch.long, device=self.device)
   DEBUG: 2026-02-20 18:00:09,659:      pdf_renderer.py:  470: printSegment:             item_seq_len = torch.tensor([len(item_history)],
   DEBUG: 2026-02-20 18:00:09,659:      pdf_renderer.py:  470: printSegment: device=self.device)
   DEBUG: 2026-02-20 18:00:09,660:      pdf_renderer.py:  470: printSegment:             seq_output = self.mamba_model.forward(item_seq,
   DEBUG: 2026-02-20 18:00:09,660:      pdf_renderer.py:  470: printSegment: item_seq_len)
   DEBUG: 2026-02-20 18:00:09,661:      pdf_renderer.py:  470: printSegment:             all_item_emb = self.mamba_model.item_embedding.weight
   DEBUG: 2026-02-20 18:00:09,662:      pdf_renderer.py:  470: printSegment:             scores = torch.matmul(seq_output,
   DEBUG: 2026-02-20 18:00:09,662:      pdf_renderer.py:  470: printSegment: all_item_emb.T).squeeze(0)
   DEBUG: 2026-02-20 18:00:09,663:      pdf_renderer.py:  470: printSegment:         top_scores, top_indices = torch.topk(scores, min(top_k,
   DEBUG: 2026-02-20 18:00:09,663:      pdf_renderer.py:  470: printSegment: len(scores)))
   DEBUG: 2026-02-20 18:00:09,663:      pdf_renderer.py:  470: printSegment:         return {
   DEBUG: 2026-02-20 18:00:09,664:      pdf_renderer.py:  470: printSegment:             int(idx): float(score)
   DEBUG: 2026-02-20 18:00:09,664:      pdf_renderer.py:  470: printSegment:             for idx, score in zip(top_indices.cpu(),
   DEBUG: 2026-02-20 18:00:09,665:      pdf_renderer.py:  470: printSegment: top_scores.cpu())
   DEBUG: 2026-02-20 18:00:09,665:      pdf_renderer.py:  470: printSegment:         }
   DEBUG: 2026-02-20 18:00:09,666:      pdf_renderer.py:  470: printSegment:     def _score_movie_for_user(
   DEBUG: 2026-02-20 18:00:09,666:      pdf_renderer.py:  470: printSegment:         self,
