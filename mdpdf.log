   DEBUG: 2026-02-20 18:00:09,090:      pdf_renderer.py:  470: printSegment:         # Normalize the blended vector
   DEBUG: 2026-02-20 18:00:09,090:      pdf_renderer.py:  470: printSegment:         norm = np.linalg.norm(search_vec)
   DEBUG: 2026-02-20 18:00:09,091:      pdf_renderer.py:  470: printSegment:         if norm > 0:
   DEBUG: 2026-02-20 18:00:09,091:      pdf_renderer.py:  470: printSegment:             search_vec = search_vec / norm
   DEBUG: 2026-02-20 18:00:09,092:      pdf_renderer.py:  470: printSegment:         search_vec = search_vec.reshape(1, -1).astype(np.float32)
   DEBUG: 2026-02-20 18:00:09,092:      pdf_renderer.py:  470: printSegment:         scores, indices = self.index.search(search_vec, top_k)
   DEBUG: 2026-02-20 18:00:09,093:      pdf_renderer.py:  470: printSegment:         results = []
