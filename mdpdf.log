   DEBUG: 2026-02-20 18:00:09,086:      pdf_renderer.py:  470: printSegment:         if query_embedding is not None and profile_embedding is not
   DEBUG: 2026-02-20 18:00:09,086:      pdf_renderer.py:  470: printSegment: None:
   DEBUG: 2026-02-20 18:00:09,087:      pdf_renderer.py:  470: printSegment:             search_vec = alpha * query_embedding + (1 - alpha) *
   DEBUG: 2026-02-20 18:00:09,087:      pdf_renderer.py:  470: printSegment: profile_embedding
   DEBUG: 2026-02-20 18:00:09,088:      pdf_renderer.py:  470: printSegment:         elif query_embedding is not None:
   DEBUG: 2026-02-20 18:00:09,088:      pdf_renderer.py:  470: printSegment:             search_vec = query_embedding
   DEBUG: 2026-02-20 18:00:09,089:      pdf_renderer.py:  470: printSegment:         else:
