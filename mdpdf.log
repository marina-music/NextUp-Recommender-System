   DEBUG: 2026-02-20 18:00:09,667:      pdf_renderer.py:  470: printSegment:         user: Dict,
   DEBUG: 2026-02-20 18:00:09,667:      pdf_renderer.py:  470: printSegment:         query_embedding: Optional[np.ndarray],
   DEBUG: 2026-02-20 18:00:09,668:      pdf_renderer.py:  470: printSegment:     ) -> float:
   DEBUG: 2026-02-20 18:00:09,668:      pdf_renderer.py:  470: printSegment:         """Score a single movie for a single user (for group
   DEBUG: 2026-02-20 18:00:09,669:      pdf_renderer.py:  470: printSegment: ranking)."""
   DEBUG: 2026-02-20 18:00:09,669:      pdf_renderer.py:  470: printSegment:         alpha = compute_alpha(
   DEBUG: 2026-02-20 18:00:09,670:      pdf_renderer.py:  470: printSegment:             query_text=None if query_embedding is None else
   DEBUG: 2026-02-20 18:00:09,670:      pdf_renderer.py:  470: printSegment: "query",
   DEBUG: 2026-02-20 18:00:09,671:      pdf_renderer.py:  470: printSegment:             has_profile=user.get("profile_embedding") is not None,
   DEBUG: 2026-02-20 18:00:09,671:      pdf_renderer.py:  470: printSegment:             home_feed_alpha=self.home_feed_alpha,
   DEBUG: 2026-02-20 18:00:09,672:      pdf_renderer.py:  470: printSegment:         )
   DEBUG: 2026-02-20 18:00:09,672:      pdf_renderer.py:  470: printSegment:         content_score = 0.0
   DEBUG: 2026-02-20 18:00:09,673:      pdf_renderer.py:  470: printSegment:         if self.content_tower:
   DEBUG: 2026-02-20 18:00:09,673:      pdf_renderer.py:  470: printSegment:             movie_emb =
   DEBUG: 2026-02-20 18:00:09,674:      pdf_renderer.py:  470: printSegment: self.content_tower.get_movie_embedding(movie_id)
   DEBUG: 2026-02-20 18:00:09,674:      pdf_renderer.py:  470: printSegment:             if movie_emb is not None:
   DEBUG: 2026-02-20 18:00:09,675:      pdf_renderer.py:  470: printSegment:                 profile = user.get("profile_embedding")
   DEBUG: 2026-02-20 18:00:09,675:      pdf_renderer.py:  470: printSegment:                 if profile is not None:
   DEBUG: 2026-02-20 18:00:09,676:      pdf_renderer.py:  470: printSegment:                     content_score = float(np.dot(movie_emb,
   DEBUG: 2026-02-20 18:00:09,676:      pdf_renderer.py:  470: printSegment: profile))
   DEBUG: 2026-02-20 18:00:09,677:      pdf_renderer.py:  470: printSegment:                 elif query_embedding is not None:
   DEBUG: 2026-02-20 18:00:09,678:      pdf_renderer.py:  470: printSegment:                     content_score = float(np.dot(movie_emb,
   DEBUG: 2026-02-20 18:00:09,678:      pdf_renderer.py:  470: printSegment: query_embedding))
   DEBUG: 2026-02-20 18:00:09,678:      pdf_renderer.py:  470: printSegment:         mamba_score = 0.0
   DEBUG: 2026-02-20 18:00:09,679:      pdf_renderer.py:  470: printSegment:         if self.mamba_model and user.get("item_history"):
   DEBUG: 2026-02-20 18:00:09,679:      pdf_renderer.py:  470: printSegment:             full_scores =
   DEBUG: 2026-02-20 18:00:09,680:      pdf_renderer.py:  470: printSegment: self._get_mamba_scores(user["item_history"], top_k=100)
   DEBUG: 2026-02-20 18:00:09,680:      pdf_renderer.py:  470: printSegment:             mamba_score = full_scores.get(movie_id, 0.0)
   DEBUG: 2026-02-20 18:00:09,681:      pdf_renderer.py:  470: printSegment:         return alpha * content_score + (1 - alpha) * mamba_score
