   DEBUG: 2026-02-20 18:00:09,755:      pdf_renderer.py:  470: printSegment: from content_tower import ContentTower
   DEBUG: 2026-02-20 18:00:09,755:      pdf_renderer.py:  470: printSegment: from reranker import Reranker, compute_alpha
