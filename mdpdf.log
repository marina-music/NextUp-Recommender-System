   DEBUG: 2026-02-20 18:00:09,258:      pdf_renderer.py:  470: printSegment: Step 3: Implement reranker.py
   DEBUG: 2026-02-20 18:00:09,259:      pdf_renderer.py:  470: printSegment: """Reranker — blends Mamba and Content Tower scores."""
   DEBUG: 2026-02-20 18:00:09,259:      pdf_renderer.py:  470: printSegment: import math
   DEBUG: 2026-02-20 18:00:09,260:      pdf_renderer.py:  470: printSegment: from typing import Dict, List, Optional
   DEBUG: 2026-02-20 18:00:09,260:      pdf_renderer.py:  470: printSegment: import numpy as np
   DEBUG: 2026-02-20 18:00:09,261:      pdf_renderer.py:  470: printSegment: def min_max_normalize(scores: Dict, epsilon: float = 1e-8) -> Dict:
   DEBUG: 2026-02-20 18:00:09,261:      pdf_renderer.py:  470: printSegment:     """Min-max normalize a dict of scores to [0, 1]."""
   DEBUG: 2026-02-20 18:00:09,262:      pdf_renderer.py:  470: printSegment:     if not scores:
   DEBUG: 2026-02-20 18:00:09,262:      pdf_renderer.py:  470: printSegment:         return {}
   DEBUG: 2026-02-20 18:00:09,263:      pdf_renderer.py:  470: printSegment:     values = list(scores.values())
   DEBUG: 2026-02-20 18:00:09,263:      pdf_renderer.py:  470: printSegment:     lo, hi = min(values), max(values)
   DEBUG: 2026-02-20 18:00:09,264:      pdf_renderer.py:  470: printSegment:     spread = hi - lo
   DEBUG: 2026-02-20 18:00:09,264:      pdf_renderer.py:  470: printSegment:     if spread < epsilon:
   DEBUG: 2026-02-20 18:00:09,265:      pdf_renderer.py:  470: printSegment:         return {k: 1.0 for k in scores}
   DEBUG: 2026-02-20 18:00:09,265:      pdf_renderer.py:  470: printSegment:     return {k: (v - lo) / spread for k, v in scores.items()}
   DEBUG: 2026-02-20 18:00:09,266:      pdf_renderer.py:  470: printSegment: def compute_alpha(
   DEBUG: 2026-02-20 18:00:09,267:      pdf_renderer.py:  470: printSegment:     query_text: Optional[str] = None,
   DEBUG: 2026-02-20 18:00:09,267:      pdf_renderer.py:  470: printSegment:     has_profile: bool = False,
   DEBUG: 2026-02-20 18:00:09,267:      pdf_renderer.py:  470: printSegment:     home_feed_alpha: float = 0.2,
   DEBUG: 2026-02-20 18:00:09,268:      pdf_renderer.py:  470: printSegment:     alpha_min: float = 0.3,
   DEBUG: 2026-02-20 18:00:09,268:      pdf_renderer.py:  470: printSegment:     alpha_max: float = 0.9,
   DEBUG: 2026-02-20 18:00:09,269:      pdf_renderer.py:  470: printSegment: ) -> float:
   DEBUG: 2026-02-20 18:00:09,269:      pdf_renderer.py:  470: printSegment:     """Compute blend alpha from query specificity.
   DEBUG: 2026-02-20 18:00:09,269:      pdf_renderer.py:  470: printSegment:     Returns:
   DEBUG: 2026-02-20 18:00:09,270:      pdf_renderer.py:  470: printSegment:         Alpha in [0, 1] where higher = trust content more.
   DEBUG: 2026-02-20 18:00:09,270:      pdf_renderer.py:  470: printSegment:     """
   DEBUG: 2026-02-20 18:00:09,271:      pdf_renderer.py:  470: printSegment:     if query_text is None:
   DEBUG: 2026-02-20 18:00:09,271:      pdf_renderer.py:  470: printSegment:         if has_profile:
   DEBUG: 2026-02-20 18:00:09,271:      pdf_renderer.py:  470: printSegment:             return home_feed_alpha
   DEBUG: 2026-02-20 18:00:09,272:      pdf_renderer.py:  470: printSegment:         return 0.0
   DEBUG: 2026-02-20 18:00:09,272:      pdf_renderer.py:  470: printSegment:     words = query_text.split()
   DEBUG: 2026-02-20 18:00:09,272:      pdf_renderer.py:  470: printSegment:     word_count = len(words)
   DEBUG: 2026-02-20 18:00:09,273:      pdf_renderer.py:  470: printSegment:     # Simple heuristic: more words → more specific → higher alpha
   DEBUG: 2026-02-20 18:00:09,273:      pdf_renderer.py:  470: printSegment:     # Sigmoid mapping: 2 words → ~0.4, 5 words → ~0.6, 10+ words → ~0.8
   DEBUG: 2026-02-20 18:00:09,274:      pdf_renderer.py:  470: printSegment:     raw = 0.3 * word_count - 1.0
   DEBUG: 2026-02-20 18:00:09,274:      pdf_renderer.py:  470: printSegment:     alpha = 1.0 / (1.0 + math.exp(-raw))
   DEBUG: 2026-02-20 18:00:09,275:      pdf_renderer.py:  470: printSegment:     return max(alpha_min, min(alpha_max, alpha))
   DEBUG: 2026-02-20 18:00:09,275:      pdf_renderer.py:  470: printSegment: class Reranker:
   DEBUG: 2026-02-20 18:00:09,276:      pdf_renderer.py:  470: printSegment:     """Blends scores from Mamba (behavioral) and Content Tower
   DEBUG: 2026-02-20 18:00:09,276:      pdf_renderer.py:  470: printSegment: (semantic)."""
   DEBUG: 2026-02-20 18:00:09,277:      pdf_renderer.py:  470: printSegment:     def blend(
   DEBUG: 2026-02-20 18:00:09,277:      pdf_renderer.py:  470: printSegment:         self,
   DEBUG: 2026-02-20 18:00:09,278:      pdf_renderer.py:  470: printSegment:         mamba_scores: Dict,
   DEBUG: 2026-02-20 18:00:09,278:      pdf_renderer.py:  470: printSegment:         content_scores: Dict,
   DEBUG: 2026-02-20 18:00:09,278:      pdf_renderer.py:  470: printSegment:         alpha: float,
   DEBUG: 2026-02-20 18:00:09,279:      pdf_renderer.py:  470: printSegment:         top_k: int = 10,
   DEBUG: 2026-02-20 18:00:09,279:      pdf_renderer.py:  470: printSegment:     ) -> List[Dict]:
   DEBUG: 2026-02-20 18:00:09,280:      pdf_renderer.py:  470: printSegment:         """Blend Mamba and content scores.
   DEBUG: 2026-02-20 18:00:09,280:      pdf_renderer.py:  470: printSegment:         Args:
   DEBUG: 2026-02-20 18:00:09,281:      pdf_renderer.py:  470: printSegment:             mamba_scores: {movie_id: raw_score} from Mamba arm.
   DEBUG: 2026-02-20 18:00:09,281:      pdf_renderer.py:  470: printSegment:             content_scores: {movie_id: cosine_sim} from content
   DEBUG: 2026-02-20 18:00:09,282:      pdf_renderer.py:  470: printSegment: arm.
   DEBUG: 2026-02-20 18:00:09,282:      pdf_renderer.py:  470: printSegment:             alpha: Blend weight (1.0 = content only, 0.0 = mamba
   DEBUG: 2026-02-20 18:00:09,283:      pdf_renderer.py:  470: printSegment: only).
   DEBUG: 2026-02-20 18:00:09,283:      pdf_renderer.py:  470: printSegment:             top_k: Number of results.
   DEBUG: 2026-02-20 18:00:09,284:      pdf_renderer.py:  470: printSegment:         Returns:
   DEBUG: 2026-02-20 18:00:09,284:      pdf_renderer.py:  470: printSegment:             Sorted list of {movie_id, score, mamba_score,
   DEBUG: 2026-02-20 18:00:09,285:      pdf_renderer.py:  470: printSegment: content_score}.
   DEBUG: 2026-02-20 18:00:09,285:      pdf_renderer.py:  470: printSegment:         """
   DEBUG: 2026-02-20 18:00:09,286:      pdf_renderer.py:  470: printSegment:         # Normalize mamba scores
   DEBUG: 2026-02-20 18:00:09,286:      pdf_renderer.py:  470: printSegment:         mamba_normed = min_max_normalize(mamba_scores)
   DEBUG: 2026-02-20 18:00:09,287:      pdf_renderer.py:  470: printSegment:         # Content scores are already cosine similarity [0, 1]
   DEBUG: 2026-02-20 18:00:09,287:      pdf_renderer.py:  470: printSegment:         all_ids = set(mamba_normed.keys()) |
   DEBUG: 2026-02-20 18:00:09,288:      pdf_renderer.py:  470: printSegment: set(content_scores.keys())
   DEBUG: 2026-02-20 18:00:09,288:      pdf_renderer.py:  470: printSegment:         scored = []
   DEBUG: 2026-02-20 18:00:09,289:      pdf_renderer.py:  470: printSegment:         for mid in all_ids:
   DEBUG: 2026-02-20 18:00:09,289:      pdf_renderer.py:  470: printSegment:             c_score = content_scores.get(mid, 0.0)
   DEBUG: 2026-02-20 18:00:09,290:      pdf_renderer.py:  470: printSegment:             m_score = mamba_normed.get(mid, 0.0)
   DEBUG: 2026-02-20 18:00:09,290:      pdf_renderer.py:  470: printSegment:             has_content = mid in content_scores
   DEBUG: 2026-02-20 18:00:09,291:      pdf_renderer.py:  470: printSegment:             has_mamba = mid in mamba_normed
   DEBUG: 2026-02-20 18:00:09,292:      pdf_renderer.py:  470: printSegment:             if has_content and has_mamba:
   DEBUG: 2026-02-20 18:00:09,292:      pdf_renderer.py:  470: printSegment:                 final = alpha * c_score + (1 - alpha) * m_score
   DEBUG: 2026-02-20 18:00:09,293:      pdf_renderer.py:  470: printSegment:             elif has_content:
   DEBUG: 2026-02-20 18:00:09,293:      pdf_renderer.py:  470: printSegment:                 final = alpha * c_score
   DEBUG: 2026-02-20 18:00:09,293:      pdf_renderer.py:  470: printSegment:             else:
   DEBUG: 2026-02-20 18:00:09,294:      pdf_renderer.py:  470: printSegment:                 final = (1 - alpha) * m_score
   DEBUG: 2026-02-20 18:00:09,294:      pdf_renderer.py:  470: printSegment:             scored.append({
   DEBUG: 2026-02-20 18:00:09,295:      pdf_renderer.py:  470: printSegment:                 "movie_id": mid,
   DEBUG: 2026-02-20 18:00:09,295:      pdf_renderer.py:  470: printSegment:                 "score": final,
   DEBUG: 2026-02-20 18:00:09,296:      pdf_renderer.py:  470: printSegment:                 "mamba_score": m_score if has_mamba else None,
   DEBUG: 2026-02-20 18:00:09,296:      pdf_renderer.py:  470: printSegment:                 "content_score": c_score if has_content else None,
   DEBUG: 2026-02-20 18:00:09,296:      pdf_renderer.py:  470: printSegment:             })
   DEBUG: 2026-02-20 18:00:09,297:      pdf_renderer.py:  470: printSegment:         scored.sort(key=lambda x: -x["score"])
   DEBUG: 2026-02-20 18:00:09,297:      pdf_renderer.py:  470: printSegment:         return scored[:top_k]
   DEBUG: 2026-02-20 18:00:09,298:      pdf_renderer.py:  470: printSegment:     def rank_group(
   DEBUG: 2026-02-20 18:00:09,298:      pdf_renderer.py:  470: printSegment:         self,
