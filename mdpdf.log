   DEBUG: 2026-02-20 18:00:08,755:      pdf_renderer.py:  470: printSegment:         prefixed = f"Represent this sentence for searching relevant
   DEBUG: 2026-02-20 18:00:08,756:      pdf_renderer.py:  470: printSegment: passages: {query}"
   DEBUG: 2026-02-20 18:00:08,756:      pdf_renderer.py:  470: printSegment:         return self.encode(prefixed, use_cache=False).squeeze(0)
   DEBUG: 2026-02-20 18:00:08,757:      pdf_renderer.py:  470: printSegment:     def encode_plot(self, plot_text: str) -> torch.Tensor:
   DEBUG: 2026-02-20 18:00:08,758:      pdf_renderer.py:  470: printSegment:         """Encode a movie plot/overview (document side)."""
   DEBUG: 2026-02-20 18:00:08,758:      pdf_renderer.py:  470: printSegment:         return self.encode(plot_text).squeeze(0)
   DEBUG: 2026-02-20 18:00:08,759:      pdf_renderer.py:  470: printSegment:     def encode_plots_batch(
   DEBUG: 2026-02-20 18:00:08,759:      pdf_renderer.py:  470: printSegment:         self, texts: List[str], batch_size: int = 64
   DEBUG: 2026-02-20 18:00:08,760:      pdf_renderer.py:  470: printSegment:     ) -> torch.Tensor:
