   DEBUG: 2026-02-20 18:00:09,610:      pdf_renderer.py:  470: printSegment:             mode = "dual"
   DEBUG: 2026-02-20 18:00:09,610:      pdf_renderer.py:  470: printSegment:         elif content_scores:
   DEBUG: 2026-02-20 18:00:09,611:      pdf_renderer.py:  470: printSegment:             mode = "content_only"
   DEBUG: 2026-02-20 18:00:09,611:      pdf_renderer.py:  470: printSegment:         elif mamba_scores:
   DEBUG: 2026-02-20 18:00:09,611:      pdf_renderer.py:  470: printSegment:             mode = "mamba_only"
   DEBUG: 2026-02-20 18:00:09,612:      pdf_renderer.py:  470: printSegment:         else:
