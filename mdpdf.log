   DEBUG: 2026-02-20 18:00:09,604:      pdf_renderer.py:  470: printSegment:             mamba_scores = self._get_mamba_scores(item_history,
   DEBUG: 2026-02-20 18:00:09,604:      pdf_renderer.py:  470: printSegment: top_k=50)
   DEBUG: 2026-02-20 18:00:09,604:      pdf_renderer.py:  470: printSegment:         # Exclude history
