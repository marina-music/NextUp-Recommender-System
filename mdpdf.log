   DEBUG: 2026-02-20 18:00:08,941:      pdf_renderer.py:  470: printSegment: """Encode movie plots with BGE and build FAISS index."""
   DEBUG: 2026-02-20 18:00:08,942:      pdf_renderer.py:  470: printSegment: import json
   DEBUG: 2026-02-20 18:00:08,942:      pdf_renderer.py:  470: printSegment: from pathlib import Path
   DEBUG: 2026-02-20 18:00:08,943:      pdf_renderer.py:  470: printSegment: from typing import Optional
   DEBUG: 2026-02-20 18:00:08,943:      pdf_renderer.py:  470: printSegment: import faiss
   DEBUG: 2026-02-20 18:00:08,944:      pdf_renderer.py:  470: printSegment: import numpy as np
   DEBUG: 2026-02-20 18:00:08,944:      pdf_renderer.py:  470: printSegment: import polars as pl
   DEBUG: 2026-02-20 18:00:08,944:      pdf_renderer.py:  470: printSegment: from tqdm import tqdm
   DEBUG: 2026-02-20 18:00:08,945:      pdf_renderer.py:  470: printSegment: from pipeline.download import DATA_DIR, REPORTS_DIR
   DEBUG: 2026-02-20 18:00:08,945:      pdf_renderer.py:  470: printSegment: EMBEDDING_DIM = 1024
   DEBUG: 2026-02-20 18:00:08,946:      pdf_renderer.py:  470: printSegment: DEFAULT_MODEL = "BAAI/bge-large-en-v1.5"
   DEBUG: 2026-02-20 18:00:08,946:      pdf_renderer.py:  470: printSegment: def prepend_metadata(
   DEBUG: 2026-02-20 18:00:08,947:      pdf_renderer.py:  470: printSegment:     plot_text: str,
   DEBUG: 2026-02-20 18:00:08,947:      pdf_renderer.py:  470: printSegment:     media_type: str = "Film",
   DEBUG: 2026-02-20 18:00:08,948:      pdf_renderer.py:  470: printSegment:     genres: Optional[str] = None,
   DEBUG: 2026-02-20 18:00:08,948:      pdf_renderer.py:  470: printSegment:     year: Optional[int] = None,
   DEBUG: 2026-02-20 18:00:08,949:      pdf_renderer.py:  470: printSegment:     title: Optional[str] = None,
   DEBUG: 2026-02-20 18:00:08,949:      pdf_renderer.py:  470: printSegment: ) -> str:
   DEBUG: 2026-02-20 18:00:08,950:      pdf_renderer.py:  470: printSegment:     """Prepend structured metadata to plot text for embedding
   DEBUG: 2026-02-20 18:00:08,951:      pdf_renderer.py:  470: printSegment: normalization."""
   DEBUG: 2026-02-20 18:00:08,951:      pdf_renderer.py:  470: printSegment:     parts = [media_type]
   DEBUG: 2026-02-20 18:00:08,951:      pdf_renderer.py:  470: printSegment:     if genres:
   DEBUG: 2026-02-20 18:00:08,952:      pdf_renderer.py:  470: printSegment:         parts.append(genres)
   DEBUG: 2026-02-20 18:00:08,953:      pdf_renderer.py:  470: printSegment:     if year is not None:
   DEBUG: 2026-02-20 18:00:08,953:      pdf_renderer.py:  470: printSegment:         parts.append(str(year))
   DEBUG: 2026-02-20 18:00:08,953:      pdf_renderer.py:  470: printSegment:     if title:
   DEBUG: 2026-02-20 18:00:08,954:      pdf_renderer.py:  470: printSegment:         parts.append(title)
   DEBUG: 2026-02-20 18:00:08,954:      pdf_renderer.py:  470: printSegment:     prefix = ". ".join(parts)
   DEBUG: 2026-02-20 18:00:08,955:      pdf_renderer.py:  470: printSegment:     return f"{prefix}. {plot_text}"
   DEBUG: 2026-02-20 18:00:08,955:      pdf_renderer.py:  470: printSegment: def build_faiss_index(embeddings: np.ndarray) -> faiss.IndexFlatIP:
   DEBUG: 2026-02-20 18:00:08,956:      pdf_renderer.py:  470: printSegment:     """Build a FAISS inner-product index from embeddings."""
   DEBUG: 2026-02-20 18:00:08,956:      pdf_renderer.py:  470: printSegment:     dim = embeddings.shape[1]
   DEBUG: 2026-02-20 18:00:08,957:      pdf_renderer.py:  470: printSegment:     index = faiss.IndexFlatIP(dim)
   DEBUG: 2026-02-20 18:00:08,957:      pdf_renderer.py:  470: printSegment:     # Normalize for cosine similarity via inner product
   DEBUG: 2026-02-20 18:00:08,958:      pdf_renderer.py:  470: printSegment:     faiss.normalize_L2(embeddings)
   DEBUG: 2026-02-20 18:00:08,958:      pdf_renderer.py:  470: printSegment:     index.add(embeddings)
   DEBUG: 2026-02-20 18:00:08,958:      pdf_renderer.py:  470: printSegment:     return index
   DEBUG: 2026-02-20 18:00:08,959:      pdf_renderer.py:  470: printSegment: def encode_and_build_index(
   DEBUG: 2026-02-20 18:00:08,959:      pdf_renderer.py:  470: printSegment:     plots_df: pl.DataFrame,
   DEBUG: 2026-02-20 18:00:08,960:      pdf_renderer.py:  470: printSegment:     model_name: str = DEFAULT_MODEL,
