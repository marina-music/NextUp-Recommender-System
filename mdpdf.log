   DEBUG: 2026-02-20 18:00:09,598:      pdf_renderer.py:  470: printSegment: profile_embedding is not None):
   DEBUG: 2026-02-20 18:00:09,599:      pdf_renderer.py:  470: printSegment:             content_results = self.content_tower.search(
