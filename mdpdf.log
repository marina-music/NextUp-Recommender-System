   DEBUG: 2026-02-20 18:00:09,752:      pdf_renderer.py:  470: printSegment: """Integration test for the full dual-arm pipeline."""
   DEBUG: 2026-02-20 18:00:09,753:      pdf_renderer.py:  470: printSegment: import pytest
