   DEBUG: 2026-02-20 18:00:08,843:      pdf_renderer.py:  470: printSegment: import requests
   DEBUG: 2026-02-20 18:00:08,843:      pdf_renderer.py:  470: printSegment: from pipeline.download import DATA_DIR, REPORTS_DIR
   DEBUG: 2026-02-20 18:00:08,844:      pdf_renderer.py:  470: printSegment: WIKIDATA_SPARQL_URL = "https://query.wikidata.org/sparql"
   DEBUG: 2026-02-20 18:00:08,844:      pdf_renderer.py:  470: printSegment: # Instance-of types for movies and TV
   DEBUG: 2026-02-20 18:00:08,845:      pdf_renderer.py:  470: printSegment: SPARQL_QUERY = """
   DEBUG: 2026-02-20 18:00:08,845:      pdf_renderer.py:  470: printSegment: SELECT DISTINCT ?articleTitle WHERE {{
   DEBUG: 2026-02-20 18:00:08,846:      pdf_renderer.py:  470: printSegment:   ?article schema:isPartOf <https://en.wikipedia.org/> ;
   DEBUG: 2026-02-20 18:00:08,846:      pdf_renderer.py:  470: printSegment:            schema:name ?articleTitle ;
   DEBUG: 2026-02-20 18:00:08,847:      pdf_renderer.py:  470: printSegment:            schema:about ?item .
   DEBUG: 2026-02-20 18:00:08,848:      pdf_renderer.py:  470: printSegment:   ?item wdt:P31 ?instance .
   DEBUG: 2026-02-20 18:00:08,848:      pdf_renderer.py:  470: printSegment:   VALUES ?instance {{
   DEBUG: 2026-02-20 18:00:08,849:      pdf_renderer.py:  470: printSegment:     wd:Q11424      wd:Q24856      wd:Q5398426
   DEBUG: 2026-02-20 18:00:08,849:      pdf_renderer.py:  470: printSegment:     wd:Q21191270   wd:Q24862      wd:Q506240
   DEBUG: 2026-02-20 18:00:08,850:      pdf_renderer.py:  470: printSegment:     wd:Q1261214    wd:Q63952888   wd:Q220898
   DEBUG: 2026-02-20 18:00:08,850:      pdf_renderer.py:  470: printSegment:   }}
   DEBUG: 2026-02-20 18:00:08,851:      pdf_renderer.py:  470: printSegment: }}
   DEBUG: 2026-02-20 18:00:08,851:      pdf_renderer.py:  470: printSegment: """
   DEBUG: 2026-02-20 18:00:08,852:      pdf_renderer.py:  470: printSegment: def fetch_movie_tv_titles() -> Set[str]:
   DEBUG: 2026-02-20 18:00:08,853:      pdf_renderer.py:  470: printSegment:     """Fetch all Wikipedia article titles that are movies or TV
   DEBUG: 2026-02-20 18:00:08,853:      pdf_renderer.py:  470: printSegment: from Wikidata."""
   DEBUG: 2026-02-20 18:00:08,854:      pdf_renderer.py:  470: printSegment:     headers = {
   DEBUG: 2026-02-20 18:00:08,854:      pdf_renderer.py:  470: printSegment:         "Accept": "application/sparql-results+json",
   DEBUG: 2026-02-20 18:00:08,855:      pdf_renderer.py:  470: printSegment:         "User-Agent": "Mamba4RecFusion/1.0 (research; polite)",
   DEBUG: 2026-02-20 18:00:08,856:      pdf_renderer.py:  470: printSegment:     }
   DEBUG: 2026-02-20 18:00:08,856:      pdf_renderer.py:  470: printSegment:     for attempt in range(5):
   DEBUG: 2026-02-20 18:00:08,857:      pdf_renderer.py:  470: printSegment:         try:
   DEBUG: 2026-02-20 18:00:08,857:      pdf_renderer.py:  470: printSegment:             resp = requests.get(
   DEBUG: 2026-02-20 18:00:08,858:      pdf_renderer.py:  470: printSegment:                 WIKIDATA_SPARQL_URL,
   DEBUG: 2026-02-20 18:00:08,859:      pdf_renderer.py:  470: printSegment:                 params={"query": SPARQL_QUERY},
   DEBUG: 2026-02-20 18:00:08,859:      pdf_renderer.py:  470: printSegment:                 headers=headers,
   DEBUG: 2026-02-20 18:00:08,860:      pdf_renderer.py:  470: printSegment:                 timeout=300,
   DEBUG: 2026-02-20 18:00:08,860:      pdf_renderer.py:  470: printSegment:             )
   DEBUG: 2026-02-20 18:00:08,861:      pdf_renderer.py:  470: printSegment:             if resp.status_code == 429:
   DEBUG: 2026-02-20 18:00:08,862:      pdf_renderer.py:  470: printSegment:                 wait = 30 * (attempt + 1)
   DEBUG: 2026-02-20 18:00:08,863:      pdf_renderer.py:  470: printSegment:                 print(f"  Rate limited, waiting {wait}s...")
   DEBUG: 2026-02-20 18:00:08,863:      pdf_renderer.py:  470: printSegment:                 time.sleep(wait)
   DEBUG: 2026-02-20 18:00:08,864:      pdf_renderer.py:  470: printSegment:                 continue
   DEBUG: 2026-02-20 18:00:08,865:      pdf_renderer.py:  470: printSegment:             resp.raise_for_status()
   DEBUG: 2026-02-20 18:00:08,865:      pdf_renderer.py:  470: printSegment:             data = resp.json()
   DEBUG: 2026-02-20 18:00:08,866:      pdf_renderer.py:  470: printSegment:             titles = set()
   DEBUG: 2026-02-20 18:00:08,867:      pdf_renderer.py:  470: printSegment:             for binding in data["results"]["bindings"]:
   DEBUG: 2026-02-20 18:00:08,868:      pdf_renderer.py:  470: printSegment:                 titles.add(binding["articleTitle"]["value"])
   DEBUG: 2026-02-20 18:00:08,868:      pdf_renderer.py:  470: printSegment:             return titles
   DEBUG: 2026-02-20 18:00:08,869:      pdf_renderer.py:  470: printSegment:         except Exception as e:
   DEBUG: 2026-02-20 18:00:08,870:      pdf_renderer.py:  470: printSegment:             if attempt < 4:
   DEBUG: 2026-02-20 18:00:08,871:      pdf_renderer.py:  470: printSegment:                 print(f"  Attempt {attempt + 1} failed: {e},
   DEBUG: 2026-02-20 18:00:08,871:      pdf_renderer.py:  470: printSegment: retrying...")
   DEBUG: 2026-02-20 18:00:08,872:      pdf_renderer.py:  470: printSegment:                 time.sleep(10 * (attempt + 1))
   DEBUG: 2026-02-20 18:00:08,873:      pdf_renderer.py:  470: printSegment:                 continue
   DEBUG: 2026-02-20 18:00:08,873:      pdf_renderer.py:  470: printSegment:             raise
   DEBUG: 2026-02-20 18:00:08,874:      pdf_renderer.py:  470: printSegment:     return set()
   DEBUG: 2026-02-20 18:00:08,875:      pdf_renderer.py:  470: printSegment: def filter_plots_to_movies_tv(
   DEBUG: 2026-02-20 18:00:08,876:      pdf_renderer.py:  470: printSegment:     raw_plots: pl.DataFrame, movie_tv_titles: Set[str]
   DEBUG: 2026-02-20 18:00:08,876:      pdf_renderer.py:  470: printSegment: ) -> pl.DataFrame:
   DEBUG: 2026-02-20 18:00:08,877:      pdf_renderer.py:  470: printSegment:     """Filter raw plots DataFrame to only movies/TV titles."""
   DEBUG: 2026-02-20 18:00:08,878:      pdf_renderer.py:  470: printSegment:     return
   DEBUG: 2026-02-20 18:00:08,879:      pdf_renderer.py:  470: printSegment: raw_plots.filter(pl.col("wiki_title").is_in(list(movie_tv_titles)))
   DEBUG: 2026-02-20 18:00:08,879:      pdf_renderer.py:  470: printSegment: def main():
   DEBUG: 2026-02-20 18:00:08,880:      pdf_renderer.py:  470: printSegment:     """Run the full filter pipeline."""
   DEBUG: 2026-02-20 18:00:08,881:      pdf_renderer.py:  470: printSegment:     raw_path = DATA_DIR / "wiki_plots_raw.parquet"
   DEBUG: 2026-02-20 18:00:08,881:      pdf_renderer.py:  470: printSegment:     output_path = DATA_DIR / "wiki_plots_movies_tv.parquet"
   DEBUG: 2026-02-20 18:00:08,882:      pdf_renderer.py:  470: printSegment:     if not raw_path.exists():
   DEBUG: 2026-02-20 18:00:08,883:      pdf_renderer.py:  470: printSegment:         print(f"ERROR: {raw_path} not found. Run the extraction
   DEBUG: 2026-02-20 18:00:08,883:      pdf_renderer.py:  470: printSegment: pipeline first.")
   DEBUG: 2026-02-20 18:00:08,884:      pdf_renderer.py:  470: printSegment:         return
   DEBUG: 2026-02-20 18:00:08,885:      pdf_renderer.py:  470: printSegment:     raw = pl.read_parquet(raw_path)
   DEBUG: 2026-02-20 18:00:08,885:      pdf_renderer.py:  470: printSegment:     print(f"Raw plots: {len(raw)} articles")
   DEBUG: 2026-02-20 18:00:08,886:      pdf_renderer.py:  470: printSegment:     print("Fetching movie/TV titles from Wikidata...")
   DEBUG: 2026-02-20 18:00:08,887:      pdf_renderer.py:  470: printSegment:     movie_tv_titles = fetch_movie_tv_titles()
   DEBUG: 2026-02-20 18:00:08,888:      pdf_renderer.py:  470: printSegment:     print(f"Wikidata returned {len(movie_tv_titles)} movie/TV
   DEBUG: 2026-02-20 18:00:08,889:      pdf_renderer.py:  470: printSegment: titles")
   DEBUG: 2026-02-20 18:00:08,890:      pdf_renderer.py:  470: printSegment:     filtered = filter_plots_to_movies_tv(raw, movie_tv_titles)
   DEBUG: 2026-02-20 18:00:08,891:      pdf_renderer.py:  470: printSegment:     print(f"After filtering: {len(filtered)} movie/TV articles")
   DEBUG: 2026-02-20 18:00:08,892:      pdf_renderer.py:  470: printSegment:     filtered.write_parquet(output_path)
   DEBUG: 2026-02-20 18:00:08,893:      pdf_renderer.py:  470: printSegment:     print(f"Wrote {output_path}")
   DEBUG: 2026-02-20 18:00:08,893:      pdf_renderer.py:  470: printSegment:     # Report
   DEBUG: 2026-02-20 18:00:08,894:      pdf_renderer.py:  470: printSegment:     report = {
