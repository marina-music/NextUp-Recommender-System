   DEBUG: 2026-02-20 18:00:09,376:      pdf_renderer.py:  470: printSegment:     ):
   DEBUG: 2026-02-20 18:00:09,376:      pdf_renderer.py:  470: printSegment:         self._queue_path = queue_path
   DEBUG: 2026-02-20 18:00:09,377:      pdf_renderer.py:  470: printSegment:         self._threshold = graduation_threshold
   DEBUG: 2026-02-20 18:00:09,377:      pdf_renderer.py:  470: printSegment:         self._mamba_catalog = mamba_catalog or set()
