   DEBUG: 2026-02-20 18:00:08,895:      pdf_renderer.py:  470: printSegment:         "wikidata_titles": len(movie_tv_titles),
   DEBUG: 2026-02-20 18:00:08,896:      pdf_renderer.py:  470: printSegment:         "filtered_count": len(filtered),
