   DEBUG: 2026-02-20 18:00:09,758:      pdf_renderer.py:  470: printSegment: from llm_encoder import IntentParser
   DEBUG: 2026-02-20 18:00:09,758:      pdf_renderer.py:  470: printSegment: from chat_provider import format_prompt
   DEBUG: 2026-02-20 18:00:09,758:      pdf_renderer.py:  470: printSegment: def _build_test_content_tower(n=100, dim=1024):
   DEBUG: 2026-02-20 18:00:09,759:      pdf_renderer.py:  470: printSegment:     vecs = np.random.randn(n, dim).astype(np.float32)
   DEBUG: 2026-02-20 18:00:09,759:      pdf_renderer.py:  470: printSegment:     faiss.normalize_L2(vecs)
   DEBUG: 2026-02-20 18:00:09,760:      pdf_renderer.py:  470: printSegment:     index = faiss.IndexFlatIP(dim)
   DEBUG: 2026-02-20 18:00:09,760:      pdf_renderer.py:  470: printSegment:     index.add(vecs)
   DEBUG: 2026-02-20 18:00:09,760:      pdf_renderer.py:  470: printSegment:     metadata = pl.DataFrame({
   DEBUG: 2026-02-20 18:00:09,761:      pdf_renderer.py:  470: printSegment:         "faiss_idx": list(range(n)),
   DEBUG: 2026-02-20 18:00:09,762:      pdf_renderer.py:  470: printSegment:         "movieId": list(range(1, n + 1)),
   DEBUG: 2026-02-20 18:00:09,762:      pdf_renderer.py:  470: printSegment:         "title": [f"Movie {i}" for i in range(1, n + 1)],
   DEBUG: 2026-02-20 18:00:09,763:      pdf_renderer.py:  470: printSegment:         "genres": ["Action"] * 50 + ["Comedy"] * 50,
   DEBUG: 2026-02-20 18:00:09,763:      pdf_renderer.py:  470: printSegment:     })
   DEBUG: 2026-02-20 18:00:09,764:      pdf_renderer.py:  470: printSegment:     return ContentTower(index, metadata), vecs
   DEBUG: 2026-02-20 18:00:09,764:      pdf_renderer.py:  470: printSegment: class TestFullPipeline:
   DEBUG: 2026-02-20 18:00:09,764:      pdf_renderer.py:  470: printSegment:     def test_content_only_flow(self):
   DEBUG: 2026-02-20 18:00:09,765:      pdf_renderer.py:  470: printSegment:         """User with no history, just a query."""
   DEBUG: 2026-02-20 18:00:09,765:      pdf_renderer.py:  470: printSegment:         tower, vecs = _build_test_content_tower()
   DEBUG: 2026-02-20 18:00:09,766:      pdf_renderer.py:  470: printSegment:         engine = DualArmEngine(content_tower=tower,
   DEBUG: 2026-02-20 18:00:09,766:      pdf_renderer.py:  470: printSegment: mamba_model=None)
   DEBUG: 2026-02-20 18:00:09,767:      pdf_renderer.py:  470: printSegment:         query_vec = np.random.randn(1024).astype(np.float32)
   DEBUG: 2026-02-20 18:00:09,767:      pdf_renderer.py:  470: printSegment:         query_vec /= np.linalg.norm(query_vec)
   DEBUG: 2026-02-20 18:00:09,768:      pdf_renderer.py:  470: printSegment:         results = engine.recommend(query_embedding=query_vec,
   DEBUG: 2026-02-20 18:00:09,768:      pdf_renderer.py:  470: printSegment: top_k=10)
   DEBUG: 2026-02-20 18:00:09,769:      pdf_renderer.py:  470: printSegment:         assert len(results) == 10
   DEBUG: 2026-02-20 18:00:09,769:      pdf_renderer.py:  470: printSegment:         # Scores should be descending
   DEBUG: 2026-02-20 18:00:09,770:      pdf_renderer.py:  470: printSegment:         scores = [r["score"] for r in results]
   DEBUG: 2026-02-20 18:00:09,770:      pdf_renderer.py:  470: printSegment:         assert scores == sorted(scores, reverse=True)
   DEBUG: 2026-02-20 18:00:09,771:      pdf_renderer.py:  470: printSegment:     def test_profile_builds_from_interactions(self):
   DEBUG: 2026-02-20 18:00:09,771:      pdf_renderer.py:  470: printSegment:         """Interactions should build a user profile."""
   DEBUG: 2026-02-20 18:00:09,772:      pdf_renderer.py:  470: printSegment:         tower, vecs = _build_test_content_tower()
   DEBUG: 2026-02-20 18:00:09,773:      pdf_renderer.py:  470: printSegment:         engine = DualArmEngine(content_tower=tower,
