   DEBUG: 2026-02-20 18:00:09,641:      pdf_renderer.py:  470: printSegment:             per_movie_scores, fairness_lambda=fairness_lambda,
   DEBUG: 2026-02-20 18:00:09,641:      pdf_renderer.py:  470: printSegment: top_k=top_k
   DEBUG: 2026-02-20 18:00:09,642:      pdf_renderer.py:  470: printSegment:         )
   DEBUG: 2026-02-20 18:00:09,642:      pdf_renderer.py:  470: printSegment:     def record_interaction(
   DEBUG: 2026-02-20 18:00:09,643:      pdf_renderer.py:  470: printSegment:         self,
   DEBUG: 2026-02-20 18:00:09,643:      pdf_renderer.py:  470: printSegment:         user_id: int,
   DEBUG: 2026-02-20 18:00:09,643:      pdf_renderer.py:  470: printSegment:         movie_id: int,
   DEBUG: 2026-02-20 18:00:09,644:      pdf_renderer.py:  470: printSegment:         rating_weight: float,
   DEBUG: 2026-02-20 18:00:09,644:      pdf_renderer.py:  470: printSegment:     ):
   DEBUG: 2026-02-20 18:00:09,645:      pdf_renderer.py:  470: printSegment:         """Record a user interaction and update their content
   DEBUG: 2026-02-20 18:00:09,646:      pdf_renderer.py:  470: printSegment: profile.
   DEBUG: 2026-02-20 18:00:09,646:      pdf_renderer.py:  470: printSegment:         Args:
