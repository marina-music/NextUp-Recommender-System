   DEBUG: 2026-02-20 18:00:09,594:      pdf_renderer.py:  470: printSegment:                 alpha_min=self.alpha_min,
   DEBUG: 2026-02-20 18:00:09,595:      pdf_renderer.py:  470: printSegment:                 alpha_max=self.alpha_max,
   DEBUG: 2026-02-20 18:00:09,595:      pdf_renderer.py:  470: printSegment:             )
   DEBUG: 2026-02-20 18:00:09,596:      pdf_renderer.py:  470: printSegment:         # Content arm
   DEBUG: 2026-02-20 18:00:09,597:      pdf_renderer.py:  470: printSegment:         content_scores = {}
